# Groq Cloud API key — sign up free at https://console.groq.com
GROQ_API_KEY=

# Llama 3.1 8B is fast and free on Groq; swap for llama-3.3-70b-versatile for quality
GROQ_MODEL=llama-3.1-8b-instant

# Multilingual embedding model (English + Vietnamese + 50 langs, ~470 MB on disk)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# Retrieval top-k
TOP_K=4

# Hybrid retrieval weight: 0.0 = pure dense (semantic), 1.0 = pure bm25 (keyword)
# 0.3 leans semantic but lets exact-match queries surface keyword hits.
HYBRID_ALPHA=0.3

# Local ChromaDB persistence directory
CHROMA_DIR=.chroma

# Per-IP rate limit for public demo (queries / minute)
RATE_LIMIT_PER_MINUTE=10
